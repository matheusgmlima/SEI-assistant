{
  "name": "sei-assistant",
  "private": true,
  "version": "0.1.0",
  "description": "Sistema de apoio ao SEI — TJPE",
  "scripts": {
    "dev:dashboard": "pnpm --filter dashboard dev",
    "dev:extension": "pnpm --filter extension dev",
    "build:dashboard": "pnpm --filter dashboard build",
    "build:extension": "pnpm --filter extension build",
    "build": "pnpm run build:extension && pnpm run build:dashboard",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
